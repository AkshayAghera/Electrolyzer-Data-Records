{
  "name": "electrolyser-app",
  "version": "1.0.0",
  "description": "Electrolyser Data Records (Caustic Soda Plant)",
  "main": "main.js",
  "author": "Akshay Aghera",
  "scripts": {
    "start": "electron .",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "mkdir -p www && cp index.html www/",
    "sync": "npx cap sync android"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.11.1",
    "electron": "latest"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "./icon",
        "asar": true,
        "overwrite": true,
        "extraResource": [
          "./logo.png",
          "./splash.html"
        ]
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "ElectrolyserRecords",
            "setupIcon": "./icon.ico"
          }
        }
      ]
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0"
  }
}